{
  "name": "ai-assignment-2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:mcp": "node dist/mcp-server/index.js",
    "start:playwright": "node dist/playwright/server.js",
    "start:all": "node dist/dev/servers.js",
    "dev:mcp": "ts-node-dev --respawn --transpile-only src/mcp-server/index.ts",
    "dev:playwright": "ts-node-dev --respawn --transpile-only src/playwright/server.ts",
    "prepare": "npx playwright install",
    "test:playwright": "npm run build && npx playwright test"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/multer": "^1.4.7",
    "@playwright/test": "^1.40.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/node": "^20.11.0",
    "playwright": "^1.40.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
